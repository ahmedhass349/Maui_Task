@page "/"
@page "/dashboard"
@attribute [Authorize]
@using System.Text.Json
@using Maui_Task.Shared.DTOs.Dashboard
@using Maui_Task.Shared.DTOs.Tasks
@using Maui_Task.Shared.DTOs.Auth
@using Maui_Task.Shared.Helpers
@using Maui_Task.Shared.Components
@inject Maui_Task.Shared.Services.HttpApiService Api

<div class="flex h-screen overflow-hidden bg-gray-50">
    <AppSidebar />
    
    <div class="flex-1 flex flex-col overflow-hidden">
        <AppHeader />
        
        <main class="flex-1 overflow-y-auto">
            @if (loading)
            {
                <div class="p-6">
                    <p class="text-gray-600">Loading dashboard...</p>
                </div>
            }
            else if (error != null)
            {
                <div class="p-6">
                    <div class="bg-red-50 border border-red-200 rounded-lg p-4">
                        <p class="text-red-700">@error</p>
                        <button @onclick="LoadData" class="mt-2 px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700">Retry</button>
                    </div>
                </div>
            }
            else
            {
                <div class="flex gap-6 p-6 items-start">
                    <div class="flex-1 min-w-0 space-y-6">
                        <!-- Greeting -->
                        <div>
                            <h1 class="text-3xl font-bold text-gray-900">Welcome, @(UserName ?? "User")</h1>
                            <p class="text-gray-600 mt-1">Here's what's happening with your projects today</p>
                        </div>

                        <!-- Stats Grid -->
                        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
                            <div class="bg-white border border-gray-200 rounded-xl p-6">
                                <div class="flex items-center justify-between">
                                    <div>
                                        <p class="text-sm text-gray-600">Active Tasks</p>
                                        <p class="text-2xl font-bold text-gray-900 mt-1">@Stats?.ActiveTaskCount</p>
                                    </div>
                                    <div class="bg-blue-100 p-3 rounded-lg">
                                        <svg class="size-6 text-blue-600" fill="currentColor" viewBox="0 0 24 24">
                                            <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                        </svg>
                                    </div>
                                </div>
                                <div class="flex items-center gap-1 mt-4 text-sm text-green-600">
                                    <svg class="size-4" fill="currentColor" viewBox="0 0 24 24">
                                        <path d="M13 7h-2v4H7v2h4v4h2v-4h4v-2h-4V7zm-1-5C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z"/>
                                    </svg>
                                    <span>@(ActiveTasks?.Count(t => string.Equals(t.Priority, "High", StringComparison.OrdinalIgnoreCase)) ?? 0) high priority</span>
                                </div>
                            </div>

                            <div class="bg-white border border-gray-200 rounded-xl p-6">
                                <div class="flex items-center justify-between">
                                    <div>
                                        <p class="text-sm text-gray-600">In Progress</p>
                                        <p class="text-2xl font-bold text-gray-900 mt-1">@Stats?.InProgressCount</p>
                                    </div>
                                    <div class="bg-orange-100 p-3 rounded-lg">
                                        <svg class="size-6 text-orange-600" fill="currentColor" viewBox="0 0 24 24">
                                            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                                        </svg>
                                    </div>
                                </div>
                                <div class="flex items-center gap-1 mt-4 text-sm text-gray-600">
                                    <span>@(ActiveTasks?.Count(t => t.DueDate.HasValue && (t.DueDate.Value.Date - DateTime.UtcNow.Date).Days <= 7 && (t.DueDate.Value.Date - DateTime.UtcNow.Date).Days >= 0) ?? 0) due this week</span>
                                </div>
                            </div>

                            <div class="bg-white border border-gray-200 rounded-xl p-6">
                                <div class="flex items-center justify-between">
                                    <div>
                                        <p class="text-sm text-gray-600">Projects</p>
                                        <p class="text-2xl font-bold text-gray-900 mt-1">@Stats?.ProjectCount</p>
                                    </div>
                                    <div class="bg-purple-100 p-3 rounded-lg">
                                        <svg class="size-6 text-purple-600" fill="currentColor" viewBox="0 0 24 24">
                                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                                        </svg>
                                    </div>
                                </div>
                                <div class="flex items-center gap-1 mt-4 text-sm text-gray-600">
                                    <span>@(ActiveTasks?.Select(t => t.ProjectName).Where(n => !string.IsNullOrWhiteSpace(n)).Distinct().Count() ?? 0) active projects</span>
                                </div>
                            </div>

                            <div class="bg-white border border-gray-200 rounded-xl p-6">
                                <div class="flex items-center justify-between">
                                    <div>
                                        <p class="text-sm text-gray-600">Team Members</p>
                                        <p class="text-2xl font-bold text-gray-900 mt-1">@Stats?.TeamMemberCount</p>
                                    </div>
                                    <div class="bg-green-100 p-3 rounded-lg">
                                        <svg class="size-6 text-green-600" fill="currentColor" viewBox="0 0 24 24">
                                            <path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                                        </svg>
                                    </div>
                                </div>
                                <div class="flex items-center gap-1 mt-4 text-sm text-gray-600">
                                    <span>@Stats?.TeamMemberCount team members</span>
                                </div>
                            </div>
                        </div>

                        <!-- Main Content Grid -->
                        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                            <!-- My Work -->
                            <DashboardCard title="My Work" iconName="check-square">
                                @if (ActiveTasks == null || ActiveTasks.Count == 0)
                                {
                                    <p class="text-sm text-gray-500 py-4 text-center">No tasks assigned yet</p>
                                }
                                else
                                {
                                    <div class="space-y-4 mt-2">
                                        @foreach (var task in ActiveTasks.Take(4))
                                        {
                                            <div class="flex items-start gap-3">
                                                <div class="mt-0.5 size-4 rounded-full border flex-shrink-0 @GetPriorityBorder(task.Priority) @GetPriorityBg(task.Priority)"></div>
                                                <div class="flex-1 min-w-0">
                                                    <p class="text-sm font-medium text-gray-900 truncate">@task.Title</p>
                                                    <p class="text-xs text-gray-500 truncate mt-0.5">
                                                        @(task.DueDate.HasValue ? task.DueDate.Value.ToString("yyyy-MM-dd") : "No due date")
                                                    </p>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                            </DashboardCard>

                            <!-- Assigned to Me -->
                            <DashboardCard title="Assigned to Me" iconName="users">
                                @if (ActiveTasks == null || ActiveTasks.Count == 0)
                                {
                                    <p class="text-sm text-gray-500 py-4 text-center">Nothing assigned to you</p>
                                }
                                else
                                {
                                    <div class="space-y-4 mt-2">
                                        @foreach (var task in ActiveTasks.Take(4))
                                        {
                                            <div class="flex items-start gap-3">
                                                <div class="mt-0.5 size-4 rounded-full border flex-shrink-0 @GetPriorityBorder(task.Priority) @GetPriorityBg(task.Priority)"></div>
                                                <div class="flex-1 min-w-0">
                                                    <p class="text-sm font-medium text-gray-900 truncate">@task.Title</p>
                                                    <p class="text-xs text-gray-500 truncate mt-0.5">
                                                        @(task.DueDate.HasValue ? task.DueDate.Value.ToString("yyyy-MM-dd") : "No due date")
                                                    </p>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                            </DashboardCard>

                            <!-- Recent Activity -->
                            <DashboardCard title="Recent Activity" iconName="clock">
                                @if (RecentActivity == null || RecentActivity.Count == 0)
                                {
                                    <p class="text-sm text-gray-500 py-4 text-center">No recent activity</p>
                                }
                                else
                                {
                                    <div class="space-y-4">
                                        @foreach (var activity in RecentActivity)
                                        {
                                            <div class="flex gap-3">
                                                <div class="size-8 bg-blue-100 rounded-full flex items-center justify-center flex-shrink-0">
                                                    <svg class="size-4 text-blue-600" fill="currentColor" viewBox="0 0 24 24">
                                                        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                                                    </svg>
                                                </div>
                                                <div class="flex-1">
                                                    <p class="text-sm text-gray-900">
                                                        <span class="font-medium">@activity.UserName</span> @activity.Description
                                                    </p>
                                                    <p class="text-xs text-gray-500 mt-0.5">@activity.CreatedAt.ToLocalTime().ToString("g")</p>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                            </DashboardCard>
                        </div>
                    </div>
                </div>
            }
        </main>
    </div>
</div>

@code {
    private bool loading = true;
    private string? error;
    private DashboardStatsDto? Stats;
     private List<Maui_Task.Shared.DTOs.Tasks.TaskDto>? ActiveTasks;
    private List<ActivityItemDto>? RecentActivity;
    private string? UserName;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        loading = true;
        error = null;
        try
        {
            // Load stats
            var statsResponse = await Api.GetAsync<ApiResponse<DashboardStatsDto>>("api/dashboard/stats");
            if (statsResponse?.Success == true)
            {
                Stats = statsResponse.Data;
            }

            // Load tasks
            var tasksResponse = await Api.GetAsync<ApiResponse<List<TaskDto>>>("api/tasks");
            if (tasksResponse?.Success == true)
            {
                ActiveTasks = tasksResponse.Data?.Where(t => t.Status != "Completed").ToList();
            }

            // Load activity
            var activityResponse = await Api.GetAsync<ApiResponse<List<ActivityItemDto>>>("api/dashboard/activity");
            if (activityResponse?.Success == true)
            {
                RecentActivity = activityResponse.Data;
            }

            // Get user info
            var userResponse = await Api.GetAsync<ApiResponse<UserDto>>("api/auth/me");
            if (userResponse?.Success == true)
            {
                UserName = userResponse.Data?.FullName;
            }
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            loading = false;
        }
    }

    private string GetPriorityBorder(string priority)
    {
        return priority switch
        {
            "High" => "border-red-500",
            "Medium" => "border-yellow-500",
            _ => "border-gray-300"
        };
    }

    private string GetPriorityBg(string priority)
    {
        return priority switch
        {
            "High" => "bg-red-50",
            "Medium" => "bg-yellow-50",
            _ => "bg-gray-50"
        };
    }
}
