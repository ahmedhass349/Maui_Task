@page "/"
@page "/dashboard"
@attribute [Authorize]
@using System.Text.Json
@using Maui_Task.Shared.DTOs.Dashboard
@using Maui_Task.Shared.DTOs.Tasks
@using Maui_Task.Shared.DTOs.Auth
@using Maui_Task.Shared.Helpers
@using Maui_Task.Shared.Components
@inject Maui_Task.Shared.Services.HttpApiService Api

<!-- REPLICATION-ANNOTATION: Replicated from Task_Flow/ReactApp/pages/Dashboard.tsx -->
<div class="flex h-screen overflow-hidden bg-gray-50">
    <AppSidebar />
    
    <div class="flex-1 flex flex-col overflow-hidden">
        <AppHeader />
        
        <main class="flex-1 overflow-y-auto">
            @if (loading)
            {
                <div class="p-6">
                    <p class="text-gray-600">Loading dashboard...</p>
                </div>
            }
            else if (error != null)
            {
                <div class="p-6">
                    <div class="bg-red-50 border border-red-200 rounded-lg p-4">
                        <p class="text-red-700">@error</p>
                        <button @onclick="LoadData" class="mt-2 px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700">Retry</button>
                    </div>
                </div>
            }
            else
            {
                <div class="flex gap-6 p-6 items-start">
                    <div class="flex-1 min-w-0 space-y-6">
                        <!-- Greeting -->
                        <div>
                            <h1 class="text-3xl font-bold text-gray-900">@Greeting, @(UserName ?? "User")</h1>
                            <p class="text-gray-600 mt-1">Here's what's happening with your projects today</p>
                        </div>

                        <!-- Stats Grid -->
                        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
                            <div class="bg-white border border-gray-200 rounded-xl p-6">
                                <div class="flex items-center justify-between">
                                    <div>
                                        <p class="text-sm text-gray-600">Active Tasks</p>
                                        <p class="text-2xl font-bold text-gray-900 mt-1">@Stats?.ActiveTaskCount</p>
                                    </div>
                                    <div class="bg-blue-100 p-3 rounded-lg">
                                        <svg class="size-6 text-blue-600" fill="currentColor" viewBox="0 0 24 24">
                                            <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                        </svg>
                                    </div>
                                </div>
                                <div class="flex items-center gap-1 mt-4 text-sm text-green-600">
                                    <svg class="size-4" fill="currentColor" viewBox="0 0 24 24">
                                        <path d="M13 7h-2v4H7v2h4v4h2v-4h4v-2h-4V7zm-1-5C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z"/>
                                    </svg>
                                    <span>@(ActiveTasks?.Count(t => string.Equals(t.Priority, "High", StringComparison.OrdinalIgnoreCase)) ?? 0) high priority</span>
                                </div>
                            </div>

                            <div class="bg-white border border-gray-200 rounded-xl p-6">
                                <div class="flex items-center justify-between">
                                    <div>
                                        <p class="text-sm text-gray-600">In Progress</p>
                                        <p class="text-2xl font-bold text-gray-900 mt-1">@Stats?.InProgressCount</p>
                                    </div>
                                    <div class="bg-orange-100 p-3 rounded-lg">
                                        <svg class="size-6 text-orange-600" fill="currentColor" viewBox="0 0 24 24">
                                            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                                        </svg>
                                    </div>
                                </div>
                                <div class="flex items-center gap-1 mt-4 text-sm text-gray-600">
                                    <span>@(ActiveTasks?.Count(t => t.DueDate.HasValue && (t.DueDate.Value.Date - DateTime.UtcNow.Date).Days <= 7 && (t.DueDate.Value.Date - DateTime.UtcNow.Date).Days >= 0) ?? 0) due this week</span>
                                </div>
                            </div>

                            <div class="bg-white border border-gray-200 rounded-xl p-6">
                                <div class="flex items-center justify-between">
                                    <div>
                                        <p class="text-sm text-gray-600">Projects</p>
                                        <p class="text-2xl font-bold text-gray-900 mt-1">@Stats?.ProjectCount</p>
                                    </div>
                                    <div class="bg-purple-100 p-3 rounded-lg">
                                        <svg class="size-6 text-purple-600" fill="currentColor" viewBox="0 0 24 24">
                                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                                        </svg>
                                    </div>
                                </div>
                                <div class="flex items-center gap-1 mt-4 text-sm text-gray-600">
                                    <span>@(ActiveTasks?.Select(t => t.ProjectName).Where(n => !string.IsNullOrWhiteSpace(n)).Distinct().Count() ?? 0) active projects</span>
                                </div>
                            </div>

                            <div class="bg-white border border-gray-200 rounded-xl p-6">
                                <div class="flex items-center justify-between">
                                    <div>
                                        <p class="text-sm text-gray-600">Team Members</p>
                                        <p class="text-2xl font-bold text-gray-900 mt-1">@Stats?.TeamMemberCount</p>
                                    </div>
                                    <div class="bg-green-100 p-3 rounded-lg">
                                        <svg class="size-6 text-green-600" fill="currentColor" viewBox="0 0 24 24">
                                            <path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                                        </svg>
                                    </div>
                                </div>
                                <div class="flex items-center gap-1 mt-4 text-sm text-gray-600">
                                    <span>@Stats?.TeamMemberCount team members</span>
                                </div>
                            </div>
                        </div>

                        <!-- Main Content Grid -->
                        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                            <!-- My Work -->
                            <DashboardCard title="My Work" iconName="check-square" actionLabel="View all">
                                @if (ActiveTasks == null || ActiveTasks.Count == 0)
                                {
                                    <p class="text-sm text-gray-500 py-4 text-center">No tasks assigned yet</p>
                                }
                                else
                                {
                                    <div class="space-y-4 mt-2">
                                        @foreach (var task in ActiveTasks.Take(4))
                                        {
                                            <div class="flex items-start gap-3">
                                                <div class="mt-0.5 size-4 rounded-full border flex-shrink-0 @GetPriorityBorder(task.Priority) @GetPriorityBg(task.Priority)"></div>
                                                <div class="flex-1 min-w-0">
                                                    <p class="text-sm font-medium text-gray-900 truncate">@task.Title</p>
                                                    <p class="text-xs text-gray-500 truncate mt-0.5">
                                                        @(task.DueDate.HasValue ? task.DueDate.Value.ToString("yyyy-MM-dd") : "No due date")
                                                    </p>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                            </DashboardCard>

                            <!-- Assigned to Me -->
                            <DashboardCard title="Assigned to Me" iconName="users" actionLabel="View all">
                                @if (ActiveTasks == null || ActiveTasks.Count == 0)
                                {
                                    <p class="text-sm text-gray-500 py-4 text-center">Nothing assigned to you</p>
                                }
                                else
                                {
                                    <div class="space-y-4 mt-2">
                                        @foreach (var task in ActiveTasks.Take(4))
                                        {
                                            <div class="flex items-start gap-3">
                                                <div class="mt-0.5 size-4 rounded-full border flex-shrink-0 @GetPriorityBorder(task.Priority) @GetPriorityBg(task.Priority)"></div>
                                                <div class="flex-1 min-w-0">
                                                    <p class="text-sm font-medium text-gray-900 truncate">@task.Title</p>
                                                    <p class="text-xs text-gray-500 truncate mt-0.5">
                                                        @(task.DueDate.HasValue ? task.DueDate.Value.ToString("yyyy-MM-dd") : "No due date")
                                                    </p>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                            </DashboardCard>

                            <!-- Agenda -->
                            <DashboardCard title="Agenda" iconName="calendar">
                                <p class="text-sm text-gray-500 py-4 text-center">Your calendar events will appear here</p>
                            </DashboardCard>

                            <!-- Recent Activity -->
                            <DashboardCard title="Recent Activity" iconName="clock">
                                @if (RecentActivity == null || RecentActivity.Count == 0)
                                {
                                    <p class="text-sm text-gray-500 py-4 text-center">No recent activity</p>
                                }
                                else
                                {
                                    <div class="space-y-4">
                                        @foreach (var activity in RecentActivity)
                                        {
                                            <div class="flex gap-3">
                                                <div class="size-8 bg-blue-100 rounded-full flex items-center justify-center flex-shrink-0">
                                                    <svg class="size-4 text-blue-600" fill="currentColor" viewBox="0 0 24 24">
                                                        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                                                    </svg>
                                                </div>
                                                <div class="flex-1">
                                                    <p class="text-sm text-gray-900">
                                                        <span class="font-medium">@activity.UserName</span> @activity.Description
                                                    </p>
                                                    <p class="text-xs text-gray-500 mt-0.5">@activity.CreatedAt.ToLocalTime().ToString("g")</p>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                            </DashboardCard>
                        </div>
                    </div>

                    <div class="flex flex-col gap-4 flex-shrink-0 pt-16">
                        <div class="w-[372px] p-6 bg-[#171717] shadow-[0_0_6px_rgba(0,0,0,0.25)] rounded-[30px] flex flex-col gap-3.5">
                            <div class="flex justify-between items-center">
                                <button class="text-white flex items-center cursor-pointer" @onclick="PreviousMonth" aria-label="Previous month">&lt;</button>
                                <span class="text-white text-xl font-medium tracking-[0.6px]">@CurrentMonthLabel</span>
                                <button class="text-white flex items-center cursor-pointer" @onclick="NextMonth" aria-label="Next month">&gt;</button>
                            </div>

                            <div class="flex justify-center items-center gap-4">
                                <button class="text-white/60 flex items-center cursor-pointer" @onclick="() => calYear--" aria-label="Previous year">&lt;</button>
                                <span class="text-white/60 text-[13px] font-normal tracking-[0.39px]">@calYear</span>
                                <button class="text-white/60 flex items-center cursor-pointer" @onclick="() => calYear++" aria-label="Next year">&gt;</button>
                            </div>

                            <div class="grid grid-cols-7">
                                @foreach (var dayLabel in DayLabels)
                                {
                                    <div class="h-9 flex items-center justify-center text-white text-[13px] font-normal tracking-[0.39px]">@dayLabel</div>
                                }
                            </div>

                            <div class="grid grid-cols-7 gap-y-1" role="grid" aria-label="Calendar dates">
                                @foreach (var cell in CalendarCells)
                                {
                                    var isSelected = cell.IsCurrentMonth && cell.Day == calDay;
                                    var hasTask = cell.IsCurrentMonth && HasTaskOnDate(cell.Day);
                                    var dayClass = isSelected
                                        ? "bg-[#60B8FF] text-white"
                                        : cell.IsCurrentMonth
                                            ? "text-white hover:bg-white/10"
                                            : "text-white/30";

                                    <button type="button"
                                            @onclick="() => SelectDay(cell)"
                                            class="h-9 flex items-center justify-center cursor-pointer bg-transparent border-0 p-0 relative disabled:cursor-default"
                                            disabled="@(!cell.IsCurrentMonth)">
                                        <div class="relative w-9 h-9 flex flex-col items-center justify-center rounded-full text-sm font-normal tracking-[0.42px] transition-colors duration-150 @dayClass">
                                            @cell.Day
                                            @if (hasTask)
                                            {
                                                <span class="w-1 h-1 rounded-full absolute bottom-1.5 @(isSelected ? "bg-white" : "bg-[#60B8FF]")"></span>
                                            }
                                        </div>
                                    </button>
                                }
                            </div>
                        </div>

                        <div class="w-[372px] p-6 bg-[#171717] shadow-[0_0_6px_rgba(0,0,0,0.25)] rounded-[30px] flex flex-col gap-[18px]">
                            <div class="flex justify-between items-center">
                                <span class="text-white text-2xl font-medium tracking-[0.72px]">Task Line</span>
                                <div class="h-[34px] px-3.5 bg-white/[0.10] rounded-[36px] outline outline-1 outline-offset-[-1px] outline-[#616161] flex items-center">
                                    <span class="text-white text-sm font-normal tracking-[0.42px]">@CurrentDateLabel</span>
                                </div>
                            </div>

                            <div class="max-h-[360px] overflow-y-auto space-y-2">
                                @if (!SelectedDayTasks.Any())
                                {
                                    <p class="text-sm text-slate-300">No tasks scheduled for this day.</p>
                                }
                                else
                                {
                                    @foreach (var task in SelectedDayTasks)
                                    {
                                        <div class="rounded-[10px] flex px-3 py-2 border @GetTaskLineClass(task.Priority)">
                                            <div class="flex flex-col overflow-hidden w-full">
                                                <span class="text-white text-xs font-medium truncate leading-tight tracking-[0.36px]">@task.Title</span>
                                                <span class="text-white/60 text-[10px] truncate leading-none mt-1.5">@GetTimeLabel(task.DueDate)</span>
                                            </div>
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }

            <Footer />
        </main>
    </div>
</div>

@code {
    private bool loading = true;
    private string? error;
    private DashboardStatsDto? Stats;
     private List<Maui_Task.Shared.DTOs.Tasks.TaskDto>? ActiveTasks;
    private List<ActivityItemDto>? RecentActivity;
    private string? UserName;
    private int calYear = DateTime.Today.Year;
    private int calMonth = DateTime.Today.Month - 1;
    private int calDay = DateTime.Today.Day;

    private static readonly string[] DayLabels = ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"];
    private static readonly string[] MonthNames = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];

    private string CurrentMonthLabel => $"{MonthNames[calMonth]} {calDay}, {calYear}";
    private string CurrentDateLabel => $"{calDay} {MonthNames[calMonth]} {calYear}";

    private IEnumerable<TaskDto> SelectedDayTasks =>
        (ActiveTasks ?? new List<TaskDto>())
            .Where(t => t.DueDate.HasValue)
            .Where(t => t.DueDate!.Value.Year == calYear && t.DueDate.Value.Month == calMonth + 1 && t.DueDate.Value.Day == calDay)
            .OrderBy(t => t.DueDate)
            .Take(8);

    private IEnumerable<CalendarCell> CalendarCells
    {
        get
        {
            var first = new DateTime(calYear, calMonth + 1, 1);
            var daysInMonth = DateTime.DaysInMonth(calYear, calMonth + 1);
            var daysInPrevMonth = DateTime.DaysInMonth(first.AddMonths(-1).Year, first.AddMonths(-1).Month);
            var firstWeekday = ((int)first.DayOfWeek + 6) % 7;

            var cells = new List<CalendarCell>(42);
            for (var i = firstWeekday - 1; i >= 0; i--)
            {
                cells.Add(new CalendarCell(daysInPrevMonth - i, false));
            }

            for (var d = 1; d <= daysInMonth; d++)
            {
                cells.Add(new CalendarCell(d, true));
            }

            var nextDay = 1;
            while (cells.Count < 42)
            {
                cells.Add(new CalendarCell(nextDay++, false));
            }

            return cells;
        }
    }
    private string Greeting
    {
        get
        {
            var hour = DateTime.Now.Hour;
            if (hour < 12) return "Good morning";
            if (hour < 18) return "Good afternoon";
            return "Good evening";
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        loading = true;
        error = null;
        try
        {
            var statsTask = SafeGetAsync<ApiResponse<DashboardStatsDto>>("api/dashboard/stats");
            var tasksTask = SafeGetAsync<ApiResponse<List<TaskDto>>>("api/tasks");
            var activityTask = SafeGetAsync<ApiResponse<List<ActivityItemDto>>>("api/dashboard/activity");
            var userTask = SafeGetAsync<ApiResponse<UserDto>>("api/auth/me");

            await Task.WhenAll(statsTask, tasksTask, activityTask, userTask);

            var statsResponse = await statsTask;
            if (statsResponse?.Success == true)
            {
                Stats = statsResponse.Data;
            }

            var tasksResponse = await tasksTask;
            if (tasksResponse?.Success == true)
            {
                ActiveTasks = tasksResponse.Data?.Where(t => t.Status != "Completed").ToList();
            }

            var activityResponse = await activityTask;
            if (activityResponse?.Success == true)
            {
                RecentActivity = activityResponse.Data;
            }

            var userResponse = await userTask;
            if (userResponse?.Success == true)
            {
                UserName = userResponse.Data?.FullName;
            }
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            loading = false;
        }
    }

    private async Task<T?> SafeGetAsync<T>(string uri)
    {
        try
        {
            return await Api.GetAsync<T>(uri);
        }
        catch
        {
            return default;
        }
    }

    private string GetPriorityBorder(string priority)
    {
        return priority switch
        {
            "High" => "border-red-500",
            "Medium" => "border-yellow-500",
            _ => "border-gray-300"
        };
    }

    private string GetPriorityBg(string priority)
    {
        return priority switch
        {
            "High" => "bg-red-50",
            "Medium" => "bg-yellow-50",
            _ => "bg-gray-50"
        };
    }

    private bool HasTaskOnDate(int day)
    {
        return (ActiveTasks ?? new List<TaskDto>())
            .Any(t => t.DueDate.HasValue
                && t.DueDate!.Value.Year == calYear
                && t.DueDate.Value.Month == calMonth + 1
                && t.DueDate.Value.Day == day);
    }

    private void SelectDay(CalendarCell cell)
    {
        if (!cell.IsCurrentMonth)
        {
            return;
        }

        calDay = cell.Day;
    }

    private void PreviousMonth()
    {
        if (calMonth == 0)
        {
            calMonth = 11;
            calYear--;
        }
        else
        {
            calMonth--;
        }

        calDay = Math.Min(calDay, DateTime.DaysInMonth(calYear, calMonth + 1));
    }

    private void NextMonth()
    {
        if (calMonth == 11)
        {
            calMonth = 0;
            calYear++;
        }
        else
        {
            calMonth++;
        }

        calDay = Math.Min(calDay, DateTime.DaysInMonth(calYear, calMonth + 1));
    }

    private static string GetTimeLabel(DateTime? dueDate)
    {
        if (!dueDate.HasValue)
        {
            return "No due time";
        }

        return dueDate.Value.ToLocalTime().ToString("HH:mm");
    }

    private static string GetTaskLineClass(string? priority)
    {
        return priority switch
        {
            "High" => "bg-red-500/20 border-red-500/50 hover:bg-red-500/30",
            "Medium" => "bg-yellow-500/20 border-yellow-500/50 hover:bg-yellow-500/30",
            _ => "bg-[#60B8FF]/20 border-[#60B8FF]/50 hover:bg-[#60B8FF]/30"
        };
    }

    private sealed record CalendarCell(int Day, bool IsCurrentMonth);
}
