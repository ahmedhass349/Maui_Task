@page "/signup"
@attribute [AllowAnonymous]
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using Maui_Task.Shared.DTOs.Auth
@using Maui_Task.Shared.Helpers
@inject NavigationManager NavigationManager
@inject Maui_Task.Shared.Services.AuthenticationService AuthService
@inject TaskFlowAuthStateProvider AuthState

<PageTitle>Sign Up</PageTitle>

<!-- REPLICATION-ANNOTATION: Replicated from Task_Flow/ReactApp/pages/Signup.tsx -->
<div class="min-h-screen bg-white flex">
    <div class="flex-1 flex flex-col min-h-screen relative">
        <div class="pt-[54px] pl-[55px]">
            <TaskFlowLogo />
        </div>

        <div class="flex-1 flex flex-col justify-center px-8 mx-auto w-full max-w-[462px] mt-[-100px]">
            @if (!string.IsNullOrWhiteSpace(ErrorMessage))
            {
                <div class="mb-[24px] max-w-[462px] rounded-[4px] border border-red-300 bg-red-50 px-[12px] py-[10px]">
                    <p class="text-sm text-red-700">@ErrorMessage</p>
                </div>
            }

            <EditForm Model="@Form" OnSubmit="HandleSignup" class="max-w-[462px]">
                <div class="flex gap-[22px] mb-[24px]">
                    <div class="flex-1">
                        <div class="relative rounded-[4px] @(RingClass("FirstName"))">
                            <div class="absolute border border-solid inset-0 pointer-events-none rounded-[4px] @(BorderClass("FirstName"))"></div>
                            <div class="px-[12px]">
                                <input name="firstName" value="@Form.FirstName" @oninput='e => HandleInput(e, "firstName")' placeholder="First name *" aria-label="First name" class="w-full py-4 bg-transparent font-normal text-base text-foreground tracking-[0.15px] leading-6 outline-none placeholder:text-muted-foreground" disabled="@IsSubmitting" />
                            </div>
                        </div>
                        @if (FieldErrors.ContainsKey("FirstName"))
                        {
                            <p class="mt-1 text-xs text-red-600 pl-0.5">@FieldErrors["FirstName"]</p>
                        }
                    </div>

                    <div class="flex-1">
                        <div class="relative rounded-[4px] @(RingClass("LastName"))">
                            <div class="absolute border border-solid inset-0 pointer-events-none rounded-[4px] @(BorderClass("LastName"))"></div>
                            <div class="px-[12px]">
                                <input name="lastName" value="@Form.LastName" @oninput='e => HandleInput(e, "lastName")' placeholder="Last name *" aria-label="Last name" class="w-full py-4 bg-transparent font-normal text-base text-foreground tracking-[0.15px] leading-6 outline-none placeholder:text-muted-foreground" disabled="@IsSubmitting" />
                            </div>
                        </div>
                        @if (FieldErrors.ContainsKey("LastName"))
                        {
                            <p class="mt-1 text-xs text-red-600 pl-0.5">@FieldErrors["LastName"]</p>
                        }
                    </div>
                </div>

                <div class="mb-[24px]">
                    <div class="relative rounded-[4px] w-full @(RingClass("Email"))">
                        <div class="absolute border border-solid inset-0 pointer-events-none rounded-[4px] @(BorderClass("Email"))"></div>
                        <div class="px-[12px] relative">
                            @if (!string.IsNullOrWhiteSpace(Form.Email))
                            {
                                <div class="bg-white flex h-[2px] items-center px-[4px] absolute top-0 left-[8px]">
                                    <span class="font-normal text-xs text-muted-foreground tracking-[0.15px] leading-3">Email Address</span>
                                </div>
                            }
                            <input name="email" value="@Form.Email" @oninput='e => HandleInput(e, "email")' placeholder="Email Address *" aria-label="Email Address" class="w-full py-[15px] bg-transparent font-normal text-base text-foreground tracking-[0.15px] leading-6 outline-none placeholder:text-muted-foreground" disabled="@IsSubmitting" />
                        </div>
                    </div>
                    @if (FieldErrors.ContainsKey("Email"))
                    {
                        <p class="mt-1 text-xs text-red-600 pl-0.5">@FieldErrors["Email"]</p>
                    }
                </div>

                <div class="mb-[24px]">
                    <div class="relative rounded-[4px] w-full @(RingClass("Password"))">
                        <div class="absolute border border-solid inset-0 pointer-events-none rounded-[4px] @(BorderClass("Password"))"></div>
                        <div class="px-[12px] relative">
                            @if (!string.IsNullOrWhiteSpace(Form.Password))
                            {
                                <div class="bg-white flex h-[2px] items-center px-[4px] absolute top-0 left-[8px]">
                                    <span class="font-normal text-xs text-muted-foreground tracking-[0.15px] leading-3">Password</span>
                                </div>
                            }
                            <input name="password" type="password" value="@Form.Password" @oninput='e => HandleInput(e, "password")' placeholder="Password *" aria-label="Password" class="w-full py-[15px] bg-transparent font-normal text-base text-foreground tracking-[0.15px] leading-6 outline-none placeholder:text-muted-foreground" disabled="@IsSubmitting" />
                        </div>
                    </div>
                    @if (FieldErrors.ContainsKey("Password"))
                    {
                        <p class="mt-1 text-xs text-red-600 pl-0.5">@FieldErrors["Password"]</p>
                    }
                </div>

                <div class="mb-[24px]">
                    <div class="relative rounded-[4px] w-full @(RingClass("ConfirmPassword"))">
                        <div class="absolute border border-solid inset-0 pointer-events-none rounded-[4px] @(BorderClass("ConfirmPassword"))"></div>
                        <div class="px-[12px] relative">
                            @if (!string.IsNullOrWhiteSpace(Form.ConfirmPassword))
                            {
                                <div class="bg-white flex h-[2px] items-center px-[4px] absolute top-0 left-[8px]">
                                    <span class="font-normal text-xs text-muted-foreground tracking-[0.15px] leading-3">Confirm Password</span>
                                </div>
                            }
                            <input name="confirmPassword" type="password" value="@Form.ConfirmPassword" @oninput='e => HandleInput(e, "confirmPassword")' placeholder="Confirm Password *" aria-label="Confirm Password" class="w-full py-[15px] bg-transparent font-normal text-base text-foreground tracking-[0.15px] leading-6 outline-none placeholder:text-muted-foreground" disabled="@IsSubmitting" />
                        </div>
                    </div>
                    @if (FieldErrors.ContainsKey("ConfirmPassword"))
                    {
                        <p class="mt-1 text-xs text-red-600 pl-0.5">@FieldErrors["ConfirmPassword"]</p>
                    }
                </div>

                <div class="relative rounded-[4px] w-full mb-[24px]">
                    <div class="absolute border border-[#e2e2ea] border-solid inset-0 pointer-events-none rounded-[4px]"></div>
                    <div class="px-[12px] relative">
                        @if (!string.IsNullOrWhiteSpace(Form.Company))
                        {
                            <div class="bg-white flex h-[2px] items-center px-[4px] absolute top-0 left-[8px]">
                                <span class="font-normal text-xs text-[#92929d] tracking-[0.15px] leading-3">Company name</span>
                            </div>
                        }
                        <input name="company" value="@Form.Company" @oninput='e => HandleInput(e, "company")' placeholder="Company name" aria-label="Company name" class="w-full py-[15px] bg-transparent font-normal text-base text-foreground tracking-[0.15px] leading-6 outline-none placeholder:text-muted-foreground" disabled="@IsSubmitting" />
                    </div>
                </div>

                <div class="flex gap-[22px] mb-[24px]">
                    <div class="relative rounded-[4px] flex-1">
                        <div class="absolute border border-[#e5e5e5] border-solid inset-0 pointer-events-none rounded-[4px]"></div>
                        <div class="px-[12px] relative">
                            <div class="bg-white flex h-[2px] items-center px-[4px] absolute top-0 left-[8px]">
                                <span class="font-normal text-xs text-muted-foreground tracking-[0.15px] leading-3">Country</span>
                            </div>
                            <div class="flex items-center">
                                <select name="country" value="@Form.Country" @onchange='e => HandleSelect(e, "country")' aria-label="Country" class="w-full py-[15px] bg-transparent font-normal text-base text-foreground tracking-[0.15px] leading-6 outline-none appearance-none cursor-pointer" disabled="@IsSubmitting">
                                    <option>United States</option>
                                    <option>United Kingdom</option>
                                    <option>Canada</option>
                                    <option>Australia</option>
                                    <option>Germany</option>
                                    <option>Egypt</option>
                                </select>
                                <svg aria-hidden="true" width="10" height="5" viewBox="0 0 10 5" fill="none" class="shrink-0 pointer-events-none">
                                    <path d="M0 0L5 5L10 0H0Z" fill="rgba(0,0,0,0.54)" />
                                </svg>
                            </div>
                        </div>
                    </div>

                    <div class="relative rounded-[4px] flex-1">
                        <div class="absolute border border-[#e2e2ea] border-solid inset-0 pointer-events-none rounded-[4px]"></div>
                        <div class="px-[12px] relative">
                            <div class="bg-white flex h-[2px] items-center px-[4px] absolute top-0 left-[8px]">
                                <span class="font-normal text-xs text-[#92929d] tracking-[0.15px] leading-3">Phone #</span>
                            </div>
                            <input name="phone" value="@Form.Phone" @oninput='e => HandleInput(e, "phone")' placeholder="Phone #" aria-label="Phone number" class="w-full py-[15px] bg-transparent font-normal text-base text-foreground tracking-[0.15px] leading-6 outline-none placeholder:text-muted-foreground" disabled="@IsSubmitting" />
                        </div>
                    </div>
                </div>

                <div class="relative rounded-[4px] w-full mb-[32px]">
                    <div class="absolute border border-[#e5e5e5] border-solid inset-0 pointer-events-none rounded-[4px]"></div>
                    <div class="px-[12px] relative">
                        <div class="bg-white flex h-[2px] items-center px-[4px] absolute top-0 left-[8px]">
                            <span class="font-normal text-xs text-muted-foreground tracking-[0.15px] leading-3">Default timezone</span>
                        </div>
                        <div class="flex items-center">
                            <select name="timezone" value="@Form.Timezone" @onchange='e => HandleSelect(e, "timezone")' aria-label="Default timezone" class="w-full py-[15px] bg-transparent font-normal text-base text-foreground tracking-[0.15px] leading-6 outline-none appearance-none cursor-pointer" disabled="@IsSubmitting">
                                <option>GMT-5</option>
                                <option>GMT-4</option>
                                <option>GMT+0</option>
                                <option>GMT+1</option>
                                <option>GMT+2</option>
                                <option>GMT+3</option>
                            </select>
                            <svg aria-hidden="true" width="10" height="5" viewBox="0 0 10 5" fill="none" class="shrink-0 pointer-events-none">
                                <path d="M0 0L5 5L10 0H0Z" fill="#92929D" />
                            </svg>
                        </div>
                    </div>
                </div>

                <button type="submit" disabled="@IsSubmitting" class="w-full bg-brand text-white rounded-[4px] px-[22px] py-[8px] shadow-[0px_3px_1px_-2px_rgba(0,0,0,0.2),0px_2px_2px_0px_rgba(0,0,0,0.14),0px_1px_5px_0px_rgba(0,0,0,0.12)] cursor-pointer hover:bg-brand-hover transition-colors disabled:opacity-60 disabled:cursor-not-allowed mb-[16px] flex items-center justify-center gap-[8px]">
                    <span class="font-medium text-[15px] leading-[26px] tracking-[0.46px] uppercase text-white">@(IsSubmitting ? "Creating account..." : "Sign up")</span>
                    @if (IsSubmitting)
                    {
                        <div class="h-4 w-4 animate-spin rounded-full border-2 border-white border-t-transparent"></div>
                    }
                </button>

                <button type="button" @onclick='() => NavigationManager.NavigateTo("/login")' disabled="@IsSubmitting" class="w-full bg-black text-white rounded-[4px] px-[22px] py-[8px] shadow-[0px_3px_1px_-2px_rgba(0,0,0,0.2),0px_2px_2px_0px_rgba(0,0,0,0.14),0px_1px_5px_0px_rgba(0,0,0,0.12)] cursor-pointer hover:bg-[#333] transition-colors disabled:opacity-60 disabled:cursor-not-allowed">
                    <span class="font-medium text-[15px] leading-[26px] tracking-[0.46px] uppercase text-white">BACK to login</span>
                </button>
            </EditForm>
        </div>

        <div class="pb-[20px] px-8 mx-auto">
            <AuthFooter />
        </div>
    </div>

    <div class="hidden lg:block w-[37.5%] bg-brand min-h-screen relative">
        <div class="absolute bottom-[30px] right-[30px]">
            <span class="font-bold text-lg text-white/80 tracking-[0.15px]">
                TaskFlow <span class="font-normal">Pro</span>
            </span>
        </div>
    </div>
</div>

@code {
    private class SignupFormData
    {
        public string FirstName { get; set; } = string.Empty;
        public string LastName { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
        public string ConfirmPassword { get; set; } = string.Empty;
        public string Company { get; set; } = string.Empty;
        public string Country { get; set; } = "United States";
        public string Phone { get; set; } = "+20";
        public string Timezone { get; set; } = "GMT+2";
    }

    private SignupFormData Form = new();
    private bool IsSubmitting;
    private string? ErrorMessage;
    private Dictionary<string, string> FieldErrors = new();

    private static bool IsValidEmail(string email)
        => System.Text.RegularExpressions.Regex.IsMatch(email, @"^[^\s@]+@[^\s@]+\.[^\s@]+$");

    private Dictionary<string, string> ValidateForm()
    {
        var errors = new Dictionary<string, string>();

        if (string.IsNullOrWhiteSpace(Form.FirstName))
            errors["FirstName"] = "First name is required";
        if (string.IsNullOrWhiteSpace(Form.LastName))
            errors["LastName"] = "Last name is required";

        if (string.IsNullOrWhiteSpace(Form.Email))
            errors["Email"] = "Email is required";
        else if (!IsValidEmail(Form.Email))
            errors["Email"] = "Please enter a valid email address";

        if (string.IsNullOrEmpty(Form.Password))
            errors["Password"] = "Password is required";
        else if (Form.Password.Length < 6)
            errors["Password"] = "Password must be at least 6 characters";

        if (string.IsNullOrEmpty(Form.ConfirmPassword))
            errors["ConfirmPassword"] = "Please confirm your password";
        else if (Form.Password != Form.ConfirmPassword)
            errors["ConfirmPassword"] = "Passwords do not match";

        return errors;
    }

    private string BorderClass(string field)
        => FieldErrors.ContainsKey(field) ? "border-red-500" : "border-[rgba(0,0,0,0.23)]";

    private string RingClass(string field)
        => FieldErrors.ContainsKey(field) ? "ring-1 ring-red-500" : string.Empty;

    private void HandleInput(ChangeEventArgs e, string field)
    {
        var value = e.Value?.ToString() ?? string.Empty;
        switch (field)
        {
            case "firstName": Form.FirstName = value; break;
            case "lastName": Form.LastName = value; break;
            case "email": Form.Email = value; break;
            case "password": Form.Password = value; break;
            case "confirmPassword": Form.ConfirmPassword = value; break;
            case "company": Form.Company = value; break;
            case "phone": Form.Phone = value; break;
        }

        FieldErrors.Remove(field switch
        {
            "firstName" => "FirstName",
            "lastName" => "LastName",
            "email" => "Email",
            "password" => "Password",
            "confirmPassword" => "ConfirmPassword",
            _ => string.Empty,
        });
    }

    private void HandleSelect(ChangeEventArgs e, string field)
    {
        var value = e.Value?.ToString() ?? string.Empty;
        if (field == "country") Form.Country = value;
        if (field == "timezone") Form.Timezone = value;
    }

    private async Task HandleSignup(EditContext _)
    {
        ErrorMessage = null;
        FieldErrors = ValidateForm();
        if (FieldErrors.Count > 0)
            return;

        IsSubmitting = true;
        try
        {
            var model = new RegisterRequest
            {
                FullName = $"{Form.FirstName.Trim()} {Form.LastName.Trim()}".Trim(),
                Email = Form.Email.Trim(),
                Password = Form.Password,
                ConfirmPassword = Form.ConfirmPassword,
                Company = string.IsNullOrWhiteSpace(Form.Company) ? null : Form.Company.Trim(),
                Country = string.IsNullOrWhiteSpace(Form.Country) ? null : Form.Country.Trim(),
                Phone = string.IsNullOrWhiteSpace(Form.Phone) ? null : Form.Phone.Trim(),
                Timezone = string.IsNullOrWhiteSpace(Form.Timezone) ? null : Form.Timezone.Trim(),
            };

            var result = await AuthService.LoginAsync<ApiResponse<AuthResponse>>("/api/auth/register", model);
            if (result?.Success == true && result.Data != null && !string.IsNullOrWhiteSpace(result.Data.Token))
            {
                await AuthService.SetTokenAsync(result.Data.Token);
                if (!string.IsNullOrWhiteSpace(result.Data.RefreshToken))
                {
                    await AuthService.SetRefreshTokenAsync(result.Data.RefreshToken);
                }
                AuthState.NotifyUserLoggedIn(result.Data);
                NavigationManager.NavigateTo("/", true);
                return;
            }

            ErrorMessage = result?.Message ?? "Registration failed.";
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsSubmitting = false;
        }
    }
}
