@page "/forgot-password"
@attribute [AllowAnonymous]
@using Maui_Task.Shared.DTOs.Auth
@using Maui_Task.Shared.Helpers
@inject NavigationManager NavigationManager
@inject Maui_Task.Shared.Services.IAuthService AuthService

<PageTitle>Forgot Password</PageTitle>

<div class="max-w-lg p-6">
    <h1 class="text-2xl font-semibold">Forgot password</h1>

    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <p class="text-sm text-red-700 mt-3">@ErrorMessage</p>
    }
    @if (!string.IsNullOrWhiteSpace(SuccessMessage))
    {
        <p class="text-sm text-green-700 mt-3">@SuccessMessage</p>
    }

    <EditForm Model="@Model" OnValidSubmit="HandleSubmit" class="mt-4 grid gap-3">
        <DataAnnotationsValidator />
        <InputText @bind-Value="Model.Email" class="border rounded px-3 py-2" placeholder="Email" />
        <ValidationMessage For="() => Model.Email" />

        <button type="submit" class="bg-black text-white rounded px-4 py-2 mt-2" disabled="@IsSubmitting">
            @(IsSubmitting ? "Sending..." : "Send reset instructions")
        </button>
    </EditForm>

    <button class="text-sm underline mt-4" @onclick='() => NavigationManager.NavigateTo("/login")'>Back to login</button>
</div>

@code {
    private ForgotPasswordRequest Model = new();
    private bool IsSubmitting;
    private string? ErrorMessage;
    private string? SuccessMessage;

    private async Task HandleSubmit()
    {
        ErrorMessage = null;
        SuccessMessage = null;
        IsSubmitting = true;
        try
        {
            var result = await AuthService.LoginAsync<ApiResponse<string>>("/api/auth/forgot-password", Model);
            if (result?.Success == true)
            {
                SuccessMessage = result.Message;
                NavigationManager.NavigateTo("/reset-password-sent");
                return;
            }

            ErrorMessage = result?.Message ?? "Failed to submit request.";
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsSubmitting = false;
        }
    }
}
