@page "/reset-password-sent"
@attribute [AllowAnonymous]
@inject NavigationManager NavigationManager

<PageTitle>Reset Password Email Sent</PageTitle>

<div class="max-w-lg p-6">
    <h1 class="text-2xl font-semibold">Check your email</h1>
    <p class="text-sm mt-2">If an account exists for your email, password reset instructions were sent.</p>

    <div class="mt-5 flex gap-3">
        <button class="bg-black text-white rounded px-4 py-2" @onclick='() => NavigationManager.NavigateTo("/reset-password")'>I have a token</button>
        <button class="border rounded px-4 py-2" @onclick='() => NavigationManager.NavigateTo("/login")'>Back to login</button>
    </div>
</div>
