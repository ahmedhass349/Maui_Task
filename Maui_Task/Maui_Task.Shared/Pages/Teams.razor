@page "/teams"
@attribute [Authorize]
@using Maui_Task.Shared.DTOs.Teams
@using Maui_Task.Shared.DTOs.Auth
@using Maui_Task.Shared.Helpers
@using Maui_Task.Shared.Components
@inject Maui_Task.Shared.Services.HttpApiService Api

<div class="flex h-screen overflow-hidden bg-gray-50">
    <AppSidebar />
    
    <div class="flex-1 flex flex-col overflow-hidden">
        <AppHeader />
        
        <main class="flex-1 overflow-y-auto">
            <div class="max-w-7xl mx-auto p-6 space-y-6">
                <!-- Page Header -->
                <div class="flex flex-wrap items-center justify-between gap-4">
                    <div>
                        <h1 class="text-3xl font-bold text-gray-900">Teams</h1>
                        <p class="text-gray-600 mt-1">Manage your team members and their workload</p>
                    </div>
                    <button class="rounded-lg bg-white px-4 py-2 text-sm font-medium text-gray-700 border border-gray-200 hover:bg-gray-50 transition-colors">
                        Invite Members
                    </button>
                </div>

                @if (loading)
                {
                    <div class="p-6">
                        <p class="text-gray-600">Loading team members...</p>
                    </div>
                }
                else if (error != null)
                {
                    <div class="p-6">
                        <div class="bg-red-50 border border-red-200 rounded-lg p-4">
                            <p class="text-red-700">@error</p>
                            <button @onclick="LoadData" class="mt-2 px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700">Retry</button>
                        </div>
                    </div>
                }
                else if (teamMembers.Count == 0)
                {
                    <div class="text-center py-12">
                        <div class="mx-auto w-16 h-16 bg-blue-100 rounded-lg flex items-center justify-center mb-4">
                            <svg class="w-8 h-8 text-blue-600" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                                <circle cx="9" cy="7" r="4"/>
                                <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                                <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                            </svg>
                        </div>
                        <h3 class="text-lg font-medium text-gray-900">No team members yet</h3>
                        <p class="text-gray-600 mt-1">Invite your first team member to start collaborating.</p>
                        <button class="mt-4 px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700">
                            Invite Members
                        </button>
                    </div>
                }
                else
                {
                    <!-- Stats -->
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                        <div class="bg-white border border-gray-200 rounded-xl p-6">
                            <div class="flex items-center gap-3">
                                <div class="bg-blue-100 p-3 rounded-lg">
                                    <svg class="size-6 text-blue-600" fill="currentColor" viewBox="0 0 24 24">
                                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                                        <circle cx="9" cy="7" r="4"/>
                                        <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                                        <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                                    </svg>
                                </div>
                                <div>
                                    <p class="text-sm text-gray-600">Total Members</p>
                                    <p class="text-2xl font-bold text-gray-900">@teamMembers.Count</p>
                                </div>
                            </div>
                        </div>

                        <div class="bg-white border border-gray-200 rounded-xl p-6">
                            <div class="flex items-center gap-3">
                                <div class="bg-green-100 p-3 rounded-lg">
                                    <div class="size-3 bg-green-500 rounded-full"></div>
                                </div>
                                <div>
                                    <p class="text-sm text-gray-600">Online Now</p>
                                    <p class="text-2xl font-bold text-gray-900">
                                        @teamMembers.Count(m => m.Status == "online")
                                    </p>
                                </div>
                            </div>
                        </div>

                        <div class="bg-white border border-gray-200 rounded-xl p-6">
                            <div class="flex items-center gap-3">
                                <div class="bg-purple-100 p-3 rounded-lg">
                                    <span class="text-xl font-bold text-purple-600">
                                        @teamMembers.Sum(m => m.TasksInProgress)
                                    </span>
                                </div>
                                <div>
                                    <p class="text-sm text-gray-600">Active Tasks</p>
                                    <p class="text-2xl font-bold text-gray-900">
                                        @teamMembers.Sum(m => m.TasksCompleted)
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Team Members Grid -->
                    <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
                        <div class="border-b border-gray-200 px-6 py-4">
                            <h2 class="font-semibold text-gray-900">Team Members</h2>
                        </div>
                        
                        <div class="divide-y divide-gray-200">
                            @foreach (var member in teamMembers)
                            {
                                <div class="p-6 flex items-center gap-6 hover:bg-gray-50 transition-colors">
                                    <!-- Avatar -->
                                    <div class="relative">
                                        <div class="@GetAvatarColor(teamMembers.IndexOf(member)) size-12 rounded-full flex items-center justify-center">
                                            <span class="text-white font-semibold">@GetInitials(member.Name)</span>
                                        </div>
                                        <div class="absolute bottom-0 right-0 @GetStatusColor(member.Status) size-3 border-2 border-white rounded-full"></div>
                                    </div>

                                    <!-- Info -->
                                    <div class="flex-1 min-w-0">
                                        <h3 class="font-semibold text-gray-900">@member.Name</h3>
                                        <p class="text-sm text-gray-600">@member.Role</p>
                                        <div class="flex items-center gap-1 mt-1 text-sm text-gray-500">
                                            <svg class="size-3" fill="currentColor" viewBox="0 0 24 24">
                                                <path d="M21.53 20.47l-3.66-3.66C19.195 15.24 20 13.214 20 11c0-4.97-4.03-9-9-9s-9 4.03-9 9 4.03 9 9 9c2.215 0 4.24-.804 5.808-2.13l3.66 3.66c.147.146.34.22.53.22s.385-.073.53-.22c.295-.293.295-.767.002-1.06zM3.5 11c0-4.135 3.365-7.5 7.5-7.5s7.5 3.365 7.5 7.5-3.365 7.5-7.5 7.5-7.5-3.365-7.5-7.5z"/>
                                            </svg>
                                            <span class="truncate">@member.Email</span>
                                        </div>
                                    </div>

                                    <!-- Stats -->
                                    <div class="flex gap-8">
                                        <div class="text-center">
                                            <p class="text-2xl font-bold text-gray-900">@member.TasksCompleted</p>
                                            <p class="text-xs text-gray-600">Completed</p>
                                        </div>
                                        <div class="text-center">
                                            <p class="text-2xl font-bold text-blue-600">@member.TasksInProgress</p>
                                            <p class="text-xs text-gray-600">In Progress</p>
                                        </div>
                                    </div>

                                    <!-- Actions -->
                                    <button aria-label="Member options" class="p-2 text-gray-400 hover:text-gray-600 hover:bg-gray-100 rounded-lg transition-colors">
                                        <svg class="size-5" fill="currentColor" viewBox="0 0 24 24">
                                            <path d="M12 10c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm0-6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm0 12c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z"/>
                                        </svg>
                                    </button>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>

            <Footer />
        </main>
    </div>
</div>

@code {
    private List<TeamMember> teamMembers = new();
    private bool loading = true;
    private string? error;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        loading = true;
        error = null;
        try
        {
            // Load teams
            var teamsResponse = await Api.GetAsync<ApiResponse<List<TeamDto>>>("api/teams");
            if (teamsResponse?.Success == true && teamsResponse.Data != null)
            {
                var members = new List<TeamMember>();
                foreach (var team in teamsResponse.Data)
                {
                    var membersResponse = await Api.GetAsync<ApiResponse<IEnumerable<TeamMemberDto>>>($"api/teams/{team.Id}/members");
                    var teamMembersForTeam = membersResponse?.Data?.ToList() ?? new List<TeamMemberDto>();

                    if (teamMembersForTeam.Count == 0)
                    {
                        members.Add(new TeamMember
                        {
                            Id = team.Id.ToString(),
                            Name = team.Name,
                            Role = $"Owner: {team.OwnerName}",
                            Email = $"{team.MemberCount} members",
                            Status = "online",
                            TasksCompleted = 0,
                            TasksInProgress = 0
                        });
                    }
                    else
                    {
                        members.AddRange(teamMembersForTeam.Select(member => new TeamMember
                        {
                            Id = member.UserId.ToString(),
                            Name = member.UserName,
                            Role = member.Role,
                            Email = member.Email,
                            Status = "online",
                            TasksCompleted = member.TasksCompleted,
                            TasksInProgress = member.TasksInProgress
                        }));
                    }
                }

                teamMembers = members;
            }
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            loading = false;
        }
    }

    private string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "U";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 0) return "U";
        if (parts.Length == 1) return parts[0].Substring(0, 1).ToUpper();
        return $"{parts[0][0]}{parts[1][0]}".ToUpper();
    }

    private string GetAvatarColor(int index)
    {
        var colors = new[] { "bg-blue-500", "bg-purple-500", "bg-pink-500", "bg-sky-500", "bg-green-500", "bg-orange-500" };
        return colors[index % colors.Length];
    }

    private string GetStatusColor(string status)
    {
        return status switch
        {
            "online" => "bg-green-500",
            "away" => "bg-yellow-500",
            _ => "bg-gray-400"
        };
    }

    private class TeamMember
    {
        public string Id { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string Role { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string Status { get; set; } = "offline";
        public int TasksCompleted { get; set; }
        public int TasksInProgress { get; set; }
    }
}
