@using Microsoft.AspNetCore.Components

<!-- REPLICATION-ANNOTATION: Replicated from Task_Flow/ReactApp/Components/DashboardCard.tsx -->
<div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
    <div class="border-b border-gray-200 px-6 py-4 flex items-center justify-between">
        <div class="flex items-center gap-2">
            @if (!string.IsNullOrWhiteSpace(iconName))
            {
                @RenderIcon(iconName!)
            }
            <h2 class="font-semibold text-gray-900">@title</h2>
        </div>

        @if (!string.IsNullOrWhiteSpace(actionLabel))
        {
            <button type="button" class="text-sm text-blue-600 hover:text-blue-700 font-medium">@actionLabel</button>
        }
    </div>

    <div class="p-6">
        @ChildContent
    </div>
</div>

@code {
    [Parameter] public string title { get; set; } = string.Empty;
    [Parameter] public string? iconName { get; set; }
    [Parameter] public string? actionLabel { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private static RenderFragment RenderIcon(string icon) => builder =>
    {
        var normalized = icon.Trim().ToLowerInvariant();
        var path = normalized switch
        {
            "check-square" => "M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z",
            "users" => "M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z",
            "calendar" => "M8 2v2M16 2v2M3 10h18M5 4h14a2 2 0 012 2v12a2 2 0 01-2 2H5a2 2 0 01-2-2V6a2 2 0 012-2z",
            "clock" => "M12 8v5l3 3M21 12a9 9 0 11-18 0 9 9 0 0118 0z",
            _ => "M12 2a10 10 0 100 20 10 10 0 000-20z"
        };

        builder.OpenElement(0, "svg");
        builder.AddAttribute(1, "class", "size-5 text-gray-600");
        builder.AddAttribute(2, "viewBox", "0 0 24 24");
        builder.AddAttribute(3, "fill", "none");
        builder.AddAttribute(4, "stroke", "currentColor");
        builder.AddAttribute(5, "stroke-width", "2");
        builder.AddAttribute(6, "stroke-linecap", "round");
        builder.AddAttribute(7, "stroke-linejoin", "round");
        builder.OpenElement(8, "path");
        builder.AddAttribute(9, "d", path);
        builder.CloseElement();
        builder.CloseElement();
    };
}
