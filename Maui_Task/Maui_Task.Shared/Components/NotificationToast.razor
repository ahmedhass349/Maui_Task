@*
    CLEANUP [Maui_Task.Shared/Components/NotificationToast.razor]:
    - Removed: none
    - Fixed: Verified Razor CSS escape @@keyframes is required and retained; no visual or behavioral CSS changes applied.
    - Moved: none
*@

@implements IDisposable

@if (IsVisible)
{
    <div class="notification-toast @ResolvePriorityClasses()" role="status" aria-live="polite">
        <div class="notification-toast__icon @ResolvePriorityClasses()">@ResolveIcon()</div>
        <div class="notification-toast__content">
            <p class="notification-toast__title">@Title</p>
            <p class="notification-toast__message">@Message</p>
            @if (!string.IsNullOrWhiteSpace(TimeAgo))
            {
                <p class="notification-toast__time">@TimeAgo</p>
            }
        </div>
        <div class="notification-toast__divider"></div>
        <button type="button" class="notification-toast__close" aria-label="Close" @onclick="OnCloseClicked">x</button>
    </div>
}

<style>
.notification-toast {
    position: fixed;
    top: 1rem;
    right: 1rem;
    z-index: 2000;
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    width: min(360px, calc(100vw - 2rem));
    padding: 1rem;
    border-radius: 12px;
    background: #ffffff;
    border: 1px solid #94a3b8;
    color: #111827;
    box-shadow: 0 12px 30px rgba(15, 23, 42, 0.14);
    animation: notification-toast-enter 180ms ease-out;
}

.notification-toast.priority-critical,
.notification-toast.priority-high {
    border-color: #ea580c;
}

.notification-toast.priority-medium {
    border-color: #2563eb;
}

.notification-toast.priority-normal {
    border-color: #64748b;
}

.notification-toast__icon {
    width: 2rem;
    height: 2rem;
    border-radius: 999px;
    background: #64748b;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.85rem;
    color: #ffffff;
    flex-shrink: 0;
}

.notification-toast__icon.priority-critical,
.notification-toast__icon.priority-high {
    background: #ea580c;
}

.notification-toast__icon.priority-medium {
    background: #2563eb;
}

.notification-toast__icon.priority-normal {
    background: #64748b;
}

.notification-toast__content {
    flex: 1;
    min-width: 0;
}

.notification-toast__title {
    margin: 0;
    font-size: 0.92rem;
    font-weight: 700;
    line-height: 1.2;
}

.notification-toast__message {
    margin: 0.25rem 0 0;
    font-size: 0.85rem;
    line-height: 1.35;
    color: #6b7280;
}

.notification-toast__time {
    margin: 0.45rem 0 0;
    font-size: 0.75rem;
    color: #9ca3af;
}

.notification-toast__divider {
    align-self: stretch;
    width: 1px;
    background: #e5e7eb;
}

.notification-toast__close {
    border: 0;
    background: transparent;
    color: #9ca3af;
    cursor: pointer;
    font-size: 1rem;
    line-height: 1;
    padding: 0.15rem;
}

.notification-toast__close:hover {
    color: #4b5563;
}

@@keyframes notification-toast-enter {
    from { transform: translateX(14px); opacity: 0; }
    to { transform: translateX(0); opacity: 1; }
}
</style>

@code {
    private CancellationTokenSource? _dismissCts;

    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public string Message { get; set; } = string.Empty;
    [Parameter] public string Icon { get; set; } = "bell";
    [Parameter] public string? TimeAgo { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    protected override void OnParametersSet()
    {
        if (!IsVisible)
        {
            CancelDismissTimer();
            return;
        }

        StartDismissTimer();
    }

    private async Task OnCloseClicked()
    {
        CancelDismissTimer();
        if (OnClose.HasDelegate)
        {
            await OnClose.InvokeAsync();
        }
    }

    private void StartDismissTimer()
    {
        CancelDismissTimer();
        _dismissCts = new CancellationTokenSource();
        var token = _dismissCts.Token;

        _ = Task.Run(async () =>
        {
            try
            {
                await Task.Delay(TimeSpan.FromSeconds(5), token);
                if (!token.IsCancellationRequested && OnClose.HasDelegate)
                {
                    await InvokeAsync(() => OnClose.InvokeAsync());
                }
            }
            catch (OperationCanceledException)
            {
            }
        }, token);
    }

    private void CancelDismissTimer()
    {
        if (_dismissCts == null)
        {
            return;
        }

        _dismissCts.Cancel();
        _dismissCts.Dispose();
        _dismissCts = null;
    }

    private string ResolveIcon()
    {
        var normalized = (Icon ?? string.Empty).Trim().ToLowerInvariant();
        return normalized switch
        {
            "critical" => "!",
            "high" => "!",
            "warning" => "!",
            "taskoverdue" => "!",
            "taskduesoon" => "!",
            "success" => "ok",
            "taskcompleted" => "ok",
            "taskcreated" => "ok",
            "taskupdated" => "ok",
            "taskdeleted" => "ok",
            _ => "i"
        };
    }

    private string ResolvePriorityClasses()
    {
        var normalized = (Icon ?? string.Empty).Trim().ToLowerInvariant();
        return normalized switch
        {
            "critical" or "high" or "warning" or "taskoverdue" or "taskduesoon" => "priority-critical",
            "medium" => "priority-medium",
            _ => "priority-normal"
        };
    }

    public void Dispose()
    {
        CancelDismissTimer();
    }
}
