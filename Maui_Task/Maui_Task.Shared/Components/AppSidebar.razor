@*
  UI REPLICATION [AppSidebar]:
  SOURCE: Task_Flow/ReactApp/Components/Sidebar.tsx
  TARGET: Maui_Task.Shared/Components/AppSidebar.razor
  REPLICATED:
    - Sidebar container, logo area, nav link ordering, collapse behavior, and active-link treatment
    - Blazor translation note: route matching and logout remain in existing C# logic
*@
@inject NavigationManager Nav
@inject TaskFlowAuthStateProvider AuthState
@inject Maui_Task.Shared.Services.AuthenticationService AuthService

<div class="bg-white border-r border-gray-200 flex flex-col transition-all duration-300 @(IsCollapsed ? "w-16" : "w-64")"
     @onmouseenter="Expand"
     @onmouseleave="Collapse">
    <div class="h-16 border-b border-gray-200 flex items-center justify-center overflow-hidden px-4">
        @if (IsCollapsed)
        {
            <div style="width: 40px; height: 48px; position: relative; flex-shrink: 0;">
                <div style="width: 10px; height: 10px; left: 0; top: 4px; position: absolute; background: #155EEF;"></div>
                <div style="width: 10px; height: 10px; left: 10px; top: 4px; position: absolute; opacity: 0; background: #155EEF;"></div>
                <div style="width: 10px; height: 10px; left: 20px; top: 4px; position: absolute; opacity: 0.60; background: #155EEF;"></div>
                <div style="width: 10px; height: 10px; left: 30px; top: 4px; position: absolute; opacity: 0; background: #155EEF;"></div>
                <div style="width: 10px; height: 10px; left: 0; top: 14px; position: absolute; opacity: 0; background: #155EEF;"></div>
                <div style="width: 10px; height: 10px; left: 10px; top: 14px; position: absolute; opacity: 0.60; background: #155EEF;"></div>
                <div style="width: 10px; height: 10px; left: 20px; top: 14px; position: absolute; opacity: 0.45; background: #155EEF;"></div>
                <div style="width: 10px; height: 10px; left: 30px; top: 14px; position: absolute; opacity: 0.30; background: #155EEF;"></div>
                <div style="width: 10px; height: 10px; left: 0; top: 24px; position: absolute; opacity: 0.60; background: #155EEF;"></div>
                <div style="width: 10px; height: 10px; left: 10px; top: 24px; position: absolute; opacity: 0.45; background: #155EEF;"></div>
                <div style="width: 10px; height: 10px; left: 20px; top: 24px; position: absolute; opacity: 0.30; background: #155EEF;"></div>
                <div style="width: 10px; height: 10px; left: 30px; top: 24px; position: absolute; opacity: 0.15; background: #155EEF;"></div>
                <div style="width: 10px; height: 10px; left: 0; top: 34px; position: absolute; opacity: 0; background: #155EEF;"></div>
                <div style="width: 10px; height: 10px; left: 10px; top: 34px; position: absolute; opacity: 0.30; background: #155EEF;"></div>
                <div style="width: 10px; height: 10px; left: 20px; top: 34px; position: absolute; opacity: 0.15; background: #155EEF;"></div>
                <div style="width: 10px; height: 10px; left: 30px; top: 34px; position: absolute; opacity: 0; background: #155EEF;"></div>
            </div>
        }
        else
        {
            <TaskFlowLogo />
        }
    </div>

    <nav class="flex-1 py-2">
        @foreach (var item in NavItems)
        {
            var isActive = Nav.Uri.TrimEnd('/').EndsWith(item.Path.TrimEnd('/'), StringComparison.OrdinalIgnoreCase)
                           || (item.Path == "/" && Nav.Uri.TrimEnd('/') == Nav.BaseUri.TrimEnd('/'));

            <a href="@item.Path"
               title="@(IsCollapsed ? item.Label : null)"
               style="@(isActive ? "background: #E2DEFF; border-radius: 8px;" : "border-radius: 8px;")"
               class="flex items-center gap-4 px-4 py-3 mx-2 transition-colors @(isActive ? "text-[#3C21F7]" : "text-[#878787] hover:bg-gray-100")">
                @((MarkupString)item.SvgIcon)
                @if (!IsCollapsed)
                {
                    <span class="text-base font-normal whitespace-nowrap" style="font-family: Inter, sans-serif;">@item.Label</span>
                }
            </a>
        }
    </nav>

    <div class="py-2 border-t border-gray-200">
        <button title="@(IsCollapsed ? "Log Out" : null)"
                class="flex items-center gap-4 px-4 py-3 mx-2 rounded-[8px] text-[#878787] hover:bg-gray-100 transition-colors w-[calc(100%-16px)] cursor-pointer"
                @onclick="LogoutAsync">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                <polyline points="16 17 21 12 16 7"/>
                <line x1="21" y1="12" x2="9" y2="12"/>
            </svg>
            @if (!IsCollapsed)
            {
                <span class="text-base font-normal whitespace-nowrap" style="font-family: Inter, sans-serif;">Log Out</span>
            }
        </button>
    </div>
</div>

@code {
    private bool IsCollapsed = true;

    private void Expand()  => IsCollapsed = false;
    private void Collapse() => IsCollapsed = true;

    private async Task LogoutAsync()
    {
        await AuthService.LogoutAsync();
        AuthState.NotifyUserLoggedOut();
        Nav.NavigateTo("/login", forceLoad: true);
    }

    private record NavItem(string Label, string Path, string SvgIcon);

    private static readonly NavItem[] NavItems =
    [
        new("Dashboard",     "/",              SvgIcons.Dashboard),
        new("Projects",      "/projects",      SvgIcons.Projects),
        new("My Tasks",      "/my-work",       SvgIcons.Tasks),
        new("Messages",      "/message",       SvgIcons.Messages),
        new("Notifications", "/notifications", SvgIcons.Bell),
        new("Teams",         "/teams",         SvgIcons.Users),
        new("Settings",      "/settings",      SvgIcons.Settings),
        new("Chatbot",       "/plans",         SvgIcons.Bot),
    ];

    private static class SvgIcons
    {
        public const string Dashboard = """<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>""";
        public const string Projects  = """<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>""";
        public const string Tasks     = """<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>""";
        public const string Messages  = """<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>""";
        public const string Bell      = """<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>""";
        public const string Users     = """<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>""";
        public const string Settings  = """<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>""";
        public const string Bot       = """<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="10" rx="2"/><circle cx="12" cy="5" r="2"/><path d="M12 7v4"/><line x1="8" y1="16" x2="8" y2="16"/><line x1="16" y1="16" x2="16" y2="16"/></svg>""";
    }
}
