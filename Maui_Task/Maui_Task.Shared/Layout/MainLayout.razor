@*
  UI REPLICATION [MainLayoutShell]:
  SOURCE: Task_Flow React shell pattern used by protected pages
  TARGET: Maui_Task.Shared/Layout/MainLayout.razor
  REPLICATED:
    - Removed legacy template wrapper shell that conflicted with page-level Task_Flow shell markup
    - Blazor translation note: keeps NotificationContext cascade and lifecycle behavior unchanged
*@
@inherits LayoutComponentBase
@implements IAsyncDisposable
@inject INotificationClientService NotificationContext

<CascadingValue Value="NotificationContext">
    @Body
</CascadingValue>

@code {
    protected override async Task OnInitializedAsync()
    {
        try
        {
            await NotificationContext.InitializeAsync();
        }
        catch
        {
            // Do NOT rethrow — continue rendering
        }
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await NotificationContext.DisposeAsync();
        }
        catch
        {
            // No-op on dispose failures.
        }
    }
}
