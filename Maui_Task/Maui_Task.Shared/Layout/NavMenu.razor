<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">Maui_Task</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

@inject Maui_Task.Shared.Services.AuthenticationService Auth
@inject Maui_Task.Shared.Services.SignalRService SignalR
@inject Microsoft.AspNetCore.Components.NavigationManager Navigation

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="counter">
                <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> Counter
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="weather">
                <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Weather
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="dashboard">
                <span class="bi bi-speedometer2-nav-menu" aria-hidden="true"></span> Dashboard
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="projects">
                <span class="bi bi-kanban-fill-nav-menu" aria-hidden="true"></span> Projects
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="teams">
                <span class="bi bi-people-fill-nav-menu" aria-hidden="true"></span> Teams
            </NavLink>
        </div>
    </nav>
</div>

<div class="nav-item px-3 mt-3">
    <button class="btn btn-link nav-link" @onclick="HandleLogout">Logout</button>
</div>

@code {
    private async System.Threading.Tasks.Task HandleLogout()
    {
        try
        {
            await SignalR.StopAsync();
        }
        catch { }

        try
        {
            await Auth.LogoutAsync();
        }
        catch { }

        Navigation.NavigateTo("/login");
    }
}

